{
  "name": "Lab: Secure Your AI Agents to Act on Behalf of Users",
  "version": "1.1.1",
  "resources": "resources.yml",
  "unauthenticatedTour": ".auth0/lab/guides/signin.tour",
  "postConfigureTour": ".auth0/lab/guides/01-intro.tour",
  "clients": [
    {
      "name": "Assistant0",
      "directory": "auth0-assistant0",
       "env": {
        "GOOGLE_API_KEY": "YOUR_API_KEY",
        "LANGCHAIN_CALLBACKS_BACKGROUND": "false",
        "AUTH0_SECRET": "use [openssl rand -hex 32] to generate a 32 bytes value",
        "APP_BASE_URL": "",
        "AUTH0_DOMAIN" : "$tenant_base_url",
        "AUTH0_CLIENT_ID": "$client_id",
        "AUTH0_CLIENT_SECRET" : "$client_secret"
      }
    }
  ]
}